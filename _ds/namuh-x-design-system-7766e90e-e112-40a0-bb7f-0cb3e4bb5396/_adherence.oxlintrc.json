{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/commerce/**",
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/marketing/**",
              "ui_kits/store/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:WellnessSans))/i]",
        "message": "Font not provided by the design system. Available: WellnessSans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|trailingArrow|leadingIcon|fullWidth|disabled|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, trailingArrow, leadingIcon, fullWidth, disabled, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|dark|accent|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'dark' | 'accent' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|radius|interactive|bordered|elevated|tone|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padding, radius, interactive, bordered, elevated, tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|sunken|mint|dark)$/]",
        "message": "<Card> tone must be one of 'default' | 'sunken' | 'mint' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColorOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|swatch|selected|key|ref|className|style|children)$/]",
        "message": "<ColorOption> doesn't accept that prop. Declared props: name, swatch, selected."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|disabled|showCheck|children|key|ref|className|style|children)$/]",
        "message": "<OptionPill> doesn't accept that prop. Declared props: selected, disabled, showCheck, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|selected|disabled|key|ref|className|style|children)$/]",
        "message": "<OptionRow> doesn't accept that prop. Declared props: title, description, selected, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:amount|mode|prefix|suffix|size|align|key|ref|className|style|children)$/]",
        "message": "<PriceBlock> doesn't accept that prop. Declared props: amount, mode, prefix, suffix, size, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceBlock'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:subscription|once)$/]",
        "message": "<PriceBlock> mode must be one of 'subscription' | 'once'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceBlock'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PriceBlock> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceBlock'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<PriceBlock> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|name|tag|colors|amount|priceMode|ctaLabel|ctaVariant|onCta|style|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: image, name, tag, colors, amount, priceMode, ctaLabel, ctaVariant, onCta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='priceMode'] > Literal[value!=/^(?:subscription|once)$/]",
        "message": "<ProductCard> priceMode must be one of 'subscription' | 'once'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='ctaVariant'] > Literal[value!=/^(?:primary|secondary|dark|accent|outline|ghost)$/]",
        "message": "<ProductCard> ctaVariant must be one of 'primary' | 'secondary' | 'dark' | 'accent' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RatingStars'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|showValue|count|style|key|ref|className|style|children)$/]",
        "message": "<RatingStars> doesn't accept that prop. Declared props: value, max, size, showValue, count, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: value, min, max, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|sub|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, sub."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:mint|mint-solid|blue|neutral|outline|dark)$/]",
        "message": "<Tag> tone must be one of 'mint' | 'mint-solid' | 'blue' | 'neutral' | 'outline' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToggleOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<ToggleOption> doesn't accept that prop. Declared props: value, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Button": {
        "replaces": []
